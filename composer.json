{
    "name": "philiprehberger/php-color",
    "description": "Color parsing, conversion, manipulation, and WCAG contrast checking",
    "type": "library",
    "keywords": ["color", "hex", "rgb", "hsl", "wcag", "contrast", "palette", "css-colors"],
    "homepage": "https://github.com/philiprehberger/php-color",
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\Color\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\Color\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
